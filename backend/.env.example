# ==============================================================
# TradeSpace — Backend Environment Variables
# Copy this file to backend/.env and fill in your real values.
# NEVER commit the real .env file to version control.
# ==============================================================

# ─── Database ──────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# In Docker Compose the host is the service name: postgres
DATABASE_URL=postgresql://postgres:change_me_strong_password@postgres:5432/tradespace

# ─── Application ───────────────────────────────────────────────
PORT=3000

# The URL of the frontend (used for CORS allow-origin)
CLIENT_URL=http://localhost

# The public URL of this backend server
SERVER_URL=http://localhost

# JWT secret — use a long random string in production
# Generate one with: openssl rand -hex 64
SECRET=replace_with_a_long_random_secret_string

# Set to "true" to enable AI moderation, "false" to disable
# Note: requires TF.js to load successfully (see KNOWN_LIMITATIONS.md)
ENABLE_TRADESPACE_AI=true

# ─── Stripe (Payments) ─────────────────────────────────────────
# Obtain from https://dashboard.stripe.com/apikeys
# Use sk_test_ keys for testing, sk_live_ only in production
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret

# Redirect URLs after Stripe checkout completes
STRIPE_UPON_SUCCESS_URL=http://localhost/payment-success
STRIPE_UPON_CANCEL_URL=http://localhost/payment-cancel

# ─── Twilio (Phone Verification) ───────────────────────────────
# Obtain from https://console.twilio.com
# Account SID starts with AC, Auth Token is shown in console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# Twilio Verify Service SID — create one at console.twilio.com/verify
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Email / Nodemailer ────────────────────────────────────────
# For Gmail: enable 2FA, then generate an App Password
# https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
USER_EMAIL=your_sending_email@gmail.com
USER_PASSWORD=your_email_password
SERVICE=gmail
APP_PASSWORD=your_16_char_gmail_app_password
