# ==============================================================
# TradeSpace — Root Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file to version control.
# ==============================================================

# ─── Database ──────────────────────────────────────────────────
# Used by docker-compose.yml to configure the PostgreSQL service.
# Must match the DATABASE_URL in backend/.env.example
DB_USER=postgres
DB_PASSWORD=change_me_strong_password
DB_NAME=tradespace

# ─── Compose networking ────────────────────────────────────────
# Frontend URL used by Nginx and backend CORS configuration
CLIENT_URL=http://localhost

# Used for internal service-to-service references
SERVER_URL=http://localhost
