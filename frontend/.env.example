# ==============================================================
# TradeSpace — Frontend Environment Variables
# Copy this file to frontend/.env and fill in your real values.
# NEVER commit the real .env file to version control.
#
# IMPORTANT: Vite bakes VITE_* variables into the JS bundle at
# BUILD TIME — not at runtime. If you change these values you
# must rebuild the Docker image (docker compose up --build).
# ==============================================================

# ─── Backend API URL ───────────────────────────────────────────
# The URL the browser uses to reach the backend API.
# In production this is typically your domain + /api
# In local Docker: http://localhost/api (routed through Nginx)
VITE_API_URL=http://localhost/api

# ─── Firebase ──────────────────────────────────────────────────
# Obtain from your Firebase project console:
# https://console.firebase.google.com → Project Settings → Your Apps
# These values are safe to expose in the browser bundle.
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
